<% layout("/layouts/boilerplate") -%>

<div class="container mt-4">
  <div class="row">

    <div class="col-12 mb-4">
      <img
        src="<%= listing.image.url %>"
        alt="<%= listing.title %>"
        class="w-100 rounded-4"
        style="height: 400px; object-fit: cover;"
      >
    </div>
    <div class="col-md-8">
      <h2 class="fw-bold"><%= listing.title %></h2>
      <h3 class="text-muted fs-6">Owned By : <%= listing.owner.username %></h3> <hr>
      <p class="text-muted fs-6"> <strong>About : </strong> <%= listing.description %></p>
      <hr>
      <p>
        <i class="bi bi-geo-alt-fill text-danger"></i>
        <strong>Location:</strong> <%= listing.location %>, <%= listing.country %>
      </p>
    </div>
>
    <div class="col-md-4">
      <div class="card shadow-sm border-0 p-3">
        <h5 class="fw-bold">
        <u> Price &#8377;<%= listing.price.toLocaleString("en-IN") %></u>
          <!-- <span class="fs-6 fw-normal text-muted"></span> -->
        </h5>
        <hr>

      <form action="/listings/<%= listing._id %>/listingBooked" method="get">
       <% if(!currentUser || !currentUser._id.equals(listing.owner._id)) { %>
             <button type="submit" class="btn btn-danger">
            <i class="bi bi-send-fill"></i> Book Now
          </button>
       <% } %>
       </form>
        <div>
          <% if(currentUser && currentUser._id.equals(listing.owner._id)) { %>
               <a href="/listings/<%= listing._id %>/edit" 
       class="btn btn-outline-dark w-100 mb-2">
      <i class="bi bi-pencil-fill"></i> Edit Listing
    </a>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
      <button type="submit" class="btn btn-danger w-100">
        <i class="bi bi-trash-fill"></i> Delete Listing
      </button>
    </form>       
       <% } %>
        </div>
      </div>
    </div>

    <div class="col-12 mt-4">
      <div class="card border-0 shadow-sm p-4 rounded-4">
        <h4 class="fw-bold mb-4">
          <i class="bi bi-star-fill text-warning"></i> Leave a Review
        </h4>

        <form action="/listings/<%= listing._id %>/reviews" method="post"
          class="needs-validation" novalidate>

           <fieldset class="starability-heart">
  <legend>First rating:</legend>
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset> <br>

          <div class="mb-3">
            <label for="comment" class="form-label fw-semibold">Comment</label>
            <textarea
              name="review[comment]" id="comment"
              class="form-control" rows="3"
              placeholder="Share your experience..." required
            ></textarea>
            <div class="invalid-feedback">Please write a comment before submitting.</div>
          </div>

          <button type="submit" class="btn btn-danger">
            <i class="bi bi-send-fill"></i> Submit Review
          </button>
        </form>
      </div>
    </div>
   
    <div class="col-12 mt-4">
    <h5 class="fw-bold mb-2">
        <i class="bi bi-geo-alt-fill text-danger"></i> Where you'll be
    </h5>
    <div id="map" style="height: 400px; border-radius: 12px; z-index: 0;"></div>
</div>
 
<% if(listing.geometry && listing.geometry.coordinates){ %>
<script>
    const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;

    const map = L.map('map').setView(
        [coordinates[1], coordinates[0]], 12
    );

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '© OpenStreetMap'
    }).addTo(map);

    L.marker([coordinates[1], coordinates[0]])
        .addTo(map)
        .bindPopup(`
            <b><%= listing.title %></b><br>
            <%= listing.location %>, <%= listing.country %>
        `)
        .openPopup();
</script>
<% } else { %>
    <p class="text-muted">Map not available for this listing.</p>
<% } %>

    <div class="col-12 mt-4 mb-5">
      <h4 class="fw-bold mb-3">
        <i class="bi bi-chat-left-text-fill text-secondary"></i> All Reviews
      </h4>

      <% if(listing.reviews.length === 0){ %>
        <div class="alert alert-light border text-muted rounded-4">
          <i class="bi bi-emoji-smile"></i> No reviews yet. Be the first to review!
        </div>
      <% } else { %>
        <div class="row g-3">
          <% for(let review of listing.reviews){ %>
            <div class="col-md-6">
              <div class="card border-0 shadow-sm rounded-4 p-3 h-100">

                <div class="mb-2">
                  <% for(let i = 1; i <= 5; i++){ %>
                    <% if(i <= review.rating){ %>
                      <i class="bi bi-star-fill text-warning"></i>
                    <% } else { %>
                      <i class="bi bi-star text-warning"></i>
                    <% } %>
                  <% } %>
                  <p class="starability-result" data-rating="<%= review.rating %>">
  </p>
                </div>
                  <p class="mb-2 text-dark"><%= review.postedBy.username %></p>
                <p class="mb-2 text-dark"><%= review.comment %></p>
          
                <p class="text-muted small mb-0">
                  <i class="bi bi-calendar3"></i>
                  <%= new Date(review.createdAt).toLocaleDateString("en-IN", { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
                 <% if(currentUser && currentUser._id.equals(review.postedBy._id)) { %>
<form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
    <button class="btn btn-sm btn-outline-danger mt-2">
        <i class="bi bi-trash-fill"></i> Delete
    </button>
</form>
<% } %>
              </div>
            </div>
          <% } %>

        </div>
      <% } %>
    </div>

  </div>
</div>

 