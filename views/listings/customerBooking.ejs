<% layout("/layouts/boilerplate") -%>

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">
            <i class="bi bi-bag-check-fill text-danger"></i>
            My Bookings
        </h1>

        <p class="text-muted">
            View all your booked stays and trip history
        </p>
    </div>

    <% 
        let validBookings = bookings.filter(
            booking => booking.listing
        );
    %>

    <% if(validBookings.length === 0){ %>

        <div class="card shadow-sm border-0 rounded-4 p-5 text-center">

            <i class="bi bi-calendar-x display-1 text-muted"></i>

            <h3 class="mt-3 fw-bold">
                No Bookings Yet
            </h3>

            <p class="text-muted">
                Looks like you haven’t booked any stay yet.
            </p>

            <a href="/listings" class="btn btn-danger mt-3">
                Explore Listings
            </a>

        </div>

    <% } else { %>

        <div class="row g-4">

            <% for(let booking of validBookings){ %>

                <div class="col-lg-4 col-md-6">

                    <div class="card border-0 shadow-sm rounded-4 h-100">

                        <img
                            src="<%= booking.listing.image.url %>"
                            class="card-img-top rounded-top-4"
                            style="height: 220px; object-fit: cover;"
                        >

                        <div class="card-body">

                            <h4 class="fw-bold">
                                <%= booking.listing.title %>
                            </h4>

                            <p class="text-muted mb-2">
                                <i class="bi bi-geo-alt-fill text-danger"></i>

                                <%= booking.listing.location %>,
                                <%= booking.listing.country %>
                            </p>

                            <hr>

                            <p class="mb-2">
                                <strong>Guest:</strong>
                                <%= booking.name %>
                            </p>

                            <p class="mb-2">
                                <strong>Check In:</strong>

                                <%= new Date(booking.checkIn)
                                .toLocaleDateString("en-IN") %>
                            </p>

                            <p class="mb-2">
                                <strong>Check Out:</strong>

                                <%= new Date(booking.checkOut)
                                .toLocaleDateString("en-IN") %>
                            </p>

                            <p class="mb-2">
                                <strong>Payment:</strong>
                                <%= booking.paymentMethod %>
                            </p>

                            <p class="mb-3">
                                <strong>Total Price:</strong>

                                ₹<%= booking.totalPrice
                                .toLocaleString("en-IN") %>
                            </p>

                            <a
                                href="/listings/<%= booking.listing._id %>"
                                class="btn btn-outline-dark w-100"
                            >
                                View Listing
                            </a>

                        </div>

                    </div>

                </div>

            <% } %>

        </div>

    <% } %>

</div>