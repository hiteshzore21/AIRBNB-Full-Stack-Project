<% layout("/layouts/boilerplate") -%>

<div class="container py-5">

  <div class="row justify-content-center">
    
    <div class="col-lg-8">

      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

      
        <div class="bg-danger text-white p-4">
          <h2 class="fw-bold mb-1">
            <i class="bi bi-calendar-check-fill"></i> Confirm Your Booking
          </h2>
          <p class="mb-0">Fill in your booking details below</p>
        </div>

        <div class="card-body p-4">

         <form 
  action="/listings/<%= listing._id %>/confirmBooking" 
  method="POST" 
  class="row g-3 needs-validation" 
  novalidate
>
   
            <div class="col-md-6">
              <label class="form-label fw-semibold">Full Name</label>
              <input 
                type="text" 
                name="booking[name]" 
                class="form-control rounded-3"
                placeholder="Enter your full name"
                required
              >
            </div>
         
            <div class="col-md-6">
              <label class="form-label fw-semibold">Email Address</label>
              <input 
                type="email" 
                name="booking[email]" 
                class="form-control rounded-3"
                placeholder="Enter your email"
                required
              >
            </div>

        
            <div class="col-md-6">
              <label class="form-label fw-semibold">Phone Number</label>
              <input 
                type="tel" 
                name="booking[phone]" 
                class="form-control rounded-3"
                placeholder="Enter phone number"
                 maxlength="10"
                pattern="[0-9]{10}"
                required
              >
                <div class="invalid-feedback">
    Please enter a valid 10-digit phone number.
   </div>
            </div>

           
            <div class="col-md-6">
              <label class="form-label fw-semibold">Aadhaar Number</label>
              <input 
                type="text" 
                name="booking[aadhar]" 
                class="form-control rounded-3"
                placeholder="XXXX XXXX XXXX"
                maxlength="12"
                required
              >
            </div>
   
            <div class="col-md-6">
              <label class="form-label fw-semibold">Check-In Date</label>
              <input 
                type="date" 
                name="booking[checkIn]" 
                class="form-control rounded-3"
                required
              >
            </div>

      
            <div class="col-md-6">
              <label class="form-label fw-semibold">Check-Out Date</label>
              <input 
                type="date" 
                name="booking[checkOut]" 
                class="form-control rounded-3"
                required
              >
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Guests</label>
              <select 
                name="booking[guests]" 
                class="form-select rounded-3"
                required
              >
                <option value="">Select Guests</option>
                <option value="1">1 Guest</option>
                <option value="2">2 Guests</option>
                <option value="3">3 Guests</option>
                <option value="4">4 Guests</option>
                <option value="5+">5+ Guests</option>
              </select>
            </div>

         
            <div class="col-md-6">
              <label class="form-label fw-semibold">Payment Method</label>
              <select 
                name="booking[paymentMethod]" 
                class="form-select rounded-3"
                required
              >
                <option value="">Select Payment Method</option>
                <option value="UPI">UPI</option>
                <option value="Credit Card">Credit Card</option>
                <option value="Debit Card">Debit Card</option>
                <option value="Net Banking">Net Banking</option>
                <option value="Cash">Cash at Property</option>
              </select>
            </div>

        
            <div class="col-12">
              <label class="form-label fw-semibold">Address</label>
              <textarea 
                name="booking[address]" 
                rows="3"
                class="form-control rounded-3"
                placeholder="Enter your address"
                required
              ></textarea>
            </div>

        
            <div class="col-12">
              <label class="form-label fw-semibold">Special Requests</label>
              <textarea 
                name="booking[request]" 
                rows="3"
                class="form-control rounded-3"
                placeholder="Any special requests?"
              ></textarea>
            </div>

            <div class="col-12">
              <div class="form-check">
                <input 
                  class="form-check-input" 
                  type="checkbox" 
                  required
                >
                <label class="form-check-label">
                  I agree to the booking terms and conditions
                </label>
              </div>
            </div>

          
            <div class="col-12 d-grid mt-3">
              <button class="btn btn-danger btn-lg rounded-3">
                <i class="bi bi-check-circle-fill"></i> Confirm Booking
              </button>
            </div>

          </form>

        </div>
      </div>

    </div>
  </div>
</div>